.venv/
__pycache__/
*.pyc
*.pyo
*.log
~$*

# Local installers and runtime tools should not be committed.
tools/
*.exe

# Experiment 2 capture outputs are generated locally and may contain real traffic.
实验二_Npcap抓包程序/outputs/*
!实验二_Npcap抓包程序/outputs/.gitkeep

# Realtime capture results are local runtime artifacts.
实验三_IP协议分析与流量统计/outputs/_live/*
!实验三_IP协议分析与流量统计/outputs/_live/.gitkeep
